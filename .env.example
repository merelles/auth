AUTH_DATABASE_HOST=YOUR_DATABASE_HOST
AUTH_DATABASE_PORT=YOUR_DATABASE_PORT
AUTH_DATABASE_NAME=YOUR_DATABASE_NAME
AUTH_DATABASE_USER=YOUR_DATABASE_USER
AUTH_DATABASE_PASSWORD=YOUR_DATABASE_PASSWORD
AUTH_DATABASE_URL=postgres://YOUR_DATABASE_USER:YOUR_DATABASE_PASSWORD@YOUR_DATABASE_HOST:YOUR_DATABASE_PORT/YOUR_DATABASE_NAME
AUTH_STORAGE_DIALECT=memory
AUTH_MONGODB_URI=mongodb://YOUR_MONGODB_HOST:27017
AUTH_MONGODB_DATABASE=auth
AUTH_SERVER_HOST=0.0.0.0
AUTH_SERVER_PORT=9090
REDIS_URL=redis://YOUR_REDIS_HOST:6379
AUTH_JWT_ISSUER=auth-service
AUTH_JWT_SECRET=change-me
AUTH_JWT_ACCESS_TTL_SECONDS=900
AUTH_JWT_REFRESH_TTL_SECONDS=86400
AUTH_PASSWORD_MEMORY_KIB=65536
AUTH_PASSWORD_ITERATIONS=3
AUTH_PASSWORD_PARALLELISM=1
AUTH_PASSWORD_PEPPER=m
